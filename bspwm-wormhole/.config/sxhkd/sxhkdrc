# super = windows button

# open terminal emulator
super + Return
#	kitty
	alacritty

# open fallback terminal emulator
super + shift + control + Return
	st

# open browser
super + b
	chromium

# open program launcher
super + d
	rofi -modi window,run,drun -lines 16 -padding 30 -width 45 -location 0 -show drun -sidebar-mode -columns 3 -theme solarized

# reload sxhkd keys
super + Escape
	pkill -USR1 -x sxhkd

XF86Audio{Prev,Next,Play}
	playerctl {previous,next,play-pause}

# I use pactl instead of amixer as it was easier.
# pulse is just a pipe into alsa anyways.
XF86Audio{Lower,Raise}Volume
	pactl set-sink-volume @DEFAULT_SINK@ {-,+}5%

XF86AudioMute
	pactl set-sink-mute @DEFAULT_SINK@ toggle

@Print
	scrot -ozfse 'owou $f' /tmp/screenshot.png

shift + Print
	scrot -ozfe 'owou $f' /tmp/screenshot.png

#
# lock screen
#

super + Scroll_Lock
	lock.sh

#
# bspwm
#

# quit bspwm altogether
super + shift + 0
	bspc quit

# close then kill focused app
super + {_,shift + }c
	bspc node -{c,k}

#
# focusing
#

super + {_,shift +}{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

super + {p,v,comma,period}
	bspc node -f @{parent,brother,first,second}

super + {_,shift + }{1-5,q,w,e,r,t}
	bspc {desktop -f,node -d} '^{1-9,10}'

